# -----------------------------------------------------------------------------
# PRLens environment configuration
# Copy this file to `.env` and fill in the real values. `.env` is gitignored.
# -----------------------------------------------------------------------------

# GitHub personal access token (or Actions token) used to read PRs and post
# reviews/comments. Needs `repo` scope (or `pull-requests: write` for the
# GITHUB_TOKEN in a workflow).
GITHUB_TOKEN=ghp_your_token_here

# Azure OpenAI credentials used by the LLM client.
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# Full endpoint / base URL for your Azure OpenAI deployment.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# -----------------------------------------------------------------------------
# Local testing only.
# These are provided automatically by GitHub Actions at runtime, so you only
# need to set them when running main.py locally outside of a workflow.
# -----------------------------------------------------------------------------

# Target repository in "owner/repo" form.
# GITHUB_REPOSITORY=owner/repo

# Path to a JSON file containing a pull_request event payload
# (must include pull_request.number).
# GITHUB_EVENT_PATH=./event.json

# Username attributed as the review actor (defaults to "local-test-user").
# GITHUB_ACTOR=your-username
