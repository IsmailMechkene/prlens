# -----------------------------------------------------------------------------
# PRLens environment configuration
# Copy this file to `.env` and fill in the real values. `.env` is gitignored.
# -----------------------------------------------------------------------------

# GitHub personal access token (or Actions token) used to read PRs and post
# reviews/comments. Needs `repo` scope (or `pull-requests: write` for the
# GITHUB_TOKEN in a workflow).
GITHUB_TOKEN=ghp_your_token_here

# Azure OpenAI credentials used by the LLM client.
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# Full endpoint / base URL for your Azure OpenAI deployment.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# -----------------------------------------------------------------------------
# Dashboard backend (prlens/webhook/app.py). Required in any deployment that
# serves the dashboard; not needed to run the reviewer from a workflow.
# -----------------------------------------------------------------------------

# Postgres connection string. Without it the app still starts and still reviews
# PRs (falling back to .aireviewer.yml), but stores nothing for the dashboard.
DATABASE_URL=postgresql://user:password@host:5432/prlens

# Shared secret GitHub signs webhook deliveries with. /webhook returns 500 until
# this is set, so a delivery is never processed unverified.
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Signing key for the session JWTs handed to the dashboard. MUST be set in
# production and MUST be the same across replicas: unset, the app falls back to a
# random per-process key, so tokens stop working at the next restart (it logs a
# warning at boot). Generate one with: python -c "import secrets;
# print(secrets.token_urlsafe(48))"
SESSION_SECRET=your_long_random_secret_here

# GitHub OAuth app used to sign users in to the dashboard.
GITHUB_OAUTH_CLIENT_ID=your_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Origin(s) the dashboard is served from: the CORS allow-list, and (first entry)
# the post-OAuth redirect target. Comma-separated, no trailing slash.
FRONTEND_URL=http://localhost:5173

# The GitHub App PRLens reviews as. The webhook server authenticates with these on
# every pull request, so a review cannot run without them — the app logs
# "GitHub App credentials OK" (or a loud failure) at boot.
GITHUB_APP_ID=your_github_app_id

# Only for GitHub Actions mode. The webhook server ignores it: every account that
# installs PRLens gets its own installation, so pinning one here would review that
# account's repos and 404 on everybody else's. It resolves the installation from the
# repo being reviewed instead.
GITHUB_APP_INSTALLATION_ID=your_installation_id

# The App's private key. In a container, use the base64 form: `*.pem` is both git-
# and docker-ignored, so GITHUB_APP_PRIVATE_KEY_PATH cannot resolve to anything in
# a deployed image. Generate with:
#   base64 -w0 prlens-reviewer.pem
GITHUB_APP_PRIVATE_KEY_B64=your_base64_encoded_pem
# Local checkouts can point at the file instead:
# GITHUB_APP_PRIVATE_KEY_PATH=prlens-reviewer.pem

# -----------------------------------------------------------------------------
# Local testing only.
# These are provided automatically by GitHub Actions at runtime, so you only
# need to set them when running main.py locally outside of a workflow.
# -----------------------------------------------------------------------------

# Target repository in "owner/repo" form.
# GITHUB_REPOSITORY=owner/repo

# Path to a JSON file containing a pull_request event payload
# (must include pull_request.number).
# GITHUB_EVENT_PATH=./event.json

# Username attributed as the review actor (defaults to "local-test-user").
# GITHUB_ACTOR=your-username
